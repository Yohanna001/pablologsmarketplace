# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- SUPABASE CONFIGURATION ---
# Option A: Client-Side Integration (Recommended for SPAs using @supabase/supabase-js)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-api-key"

# Option B: Direct Relational Database Connection (For full-stack or raw query drivers)
DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- ADMIN DASHBOARD CONFIGURATION ---
ADMIN_EMAIL=admin@purelogsmartketaplace.com
ADMIN_PASSWORD=Admin@123
JWT_SECRET=your_super_secret_jwt_key_here
SESSION_SECRET=your_session_secret_here

# --- PAYSTACK CONFIGURATION ---
# Paste your credentials from your Paystack Dashboard:
# 1. Public Key (starts with pk_test_ or pk_live_)
# 2. Secret Key (starts with sk_test_ or sk_live_)
PAYSTACK_PUBLIC_KEY=your_test_public_key
PAYSTACK_SECRET_KEY=your_test_secret_key
# For Vercel/Static client uploads, also set this so Vite can bundle it:
VITE_PAYSTACK_PUBLIC_KEY=your_test_public_key


